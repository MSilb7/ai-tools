#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/install-skills [--target all|claude|codex] [--dry-run]

Symlink every portable skill in this repository into the selected agent runtimes.

Environment overrides:
  AI_TOOLS_HOME      Stable repository anchor (default: $HOME/.ai-tools)
  CLAUDE_SKILLS_DIR  Claude Code skill directory (default: $HOME/.claude/skills)
  CLAUDE_COMMANDS_DIR  Retired Claude command-link prune directory (default: $HOME/.claude/commands)
  CODEX_SKILLS_DIR   Codex skill directory (default: $HOME/.agents/skills)
EOF
}

target="all"
dry_run=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      [[ $# -ge 2 ]] || { echo "install-skills: --target requires a value" >&2; exit 2; }
      target="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "install-skills: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$target" in
  all|claude|codex) ;;
  *)
    echo "install-skills: target must be all, claude, or codex" >&2
    exit 2
    ;;
esac

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
skills_root="$repo_root/skills"
anchor="${AI_TOOLS_HOME:-$HOME/.ai-tools}"
claude_dir="${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"
claude_commands_dir="${CLAUDE_COMMANDS_DIR:-$HOME/.claude/commands}"
codex_dir="${CODEX_SKILLS_DIR:-$HOME/.agents/skills}"

[[ -d "$skills_root" ]] || { echo "install-skills: missing skills directory: $skills_root" >&2; exit 1; }

make_dir() {
  if $dry_run; then
    printf '[dry-run] mkdir -p %s\n' "$1"
  else
    mkdir -p "$1"
  fi
}

replace_link() {
  local source="$1"
  local destination="$2"

  if [[ -L "$destination" ]]; then
    if [[ "$(readlink "$destination")" == "$source" ]]; then
      printf 'ok       %s -> %s\n' "$destination" "$source"
      return
    fi
    if $dry_run; then
      printf '[dry-run] relink %s -> %s\n' "$destination" "$source"
    else
      ln -sfn "$source" "$destination"
      printf 'relinked %s -> %s\n' "$destination" "$source"
    fi
    return
  fi

  if [[ -e "$destination" ]]; then
    printf 'conflict %s exists and is not a symlink; left unchanged\n' "$destination" >&2
    return 1
  fi

  if $dry_run; then
    printf '[dry-run] link %s -> %s\n' "$destination" "$source"
  else
    ln -s "$source" "$destination"
    printf 'linked   %s -> %s\n' "$destination" "$source"
  fi
}

install_anchor() {
  make_dir "$(dirname "$anchor")"
  replace_link "$repo_root" "$anchor"
}

# Remove symlinks that point through the anchor but whose targets no longer exist (a skill or
# command was renamed or removed). Never touches real files or links owned by anything else.
prune_stale_links() {
  local destination_root="$1"
  local entry
  local link_target

  [[ -d "$destination_root" ]] || return 0
  for entry in "$destination_root"/* "$destination_root"/.*; do
    [[ -L "$entry" ]] || continue
    link_target="$(readlink "$entry")"
    [[ "$link_target" == "$anchor"/* ]] || continue
    [[ ! -e "$entry" ]] || continue
    if $dry_run; then
      printf '[dry-run] prune %s (dangling -> %s)\n' "$entry" "$link_target"
    else
      rm "$entry"
      printf 'pruned   %s (dangling -> %s)\n' "$entry" "$link_target"
    fi
  done
}

install_target() {
  local label="$1"
  local destination_root="$2"
  local failures=0

  make_dir "$destination_root"
  for skill_dir in "$skills_root"/*; do
    [[ -d "$skill_dir" && -f "$skill_dir/SKILL.md" ]] || continue
    local skill_name
    skill_name="$(basename "$skill_dir")"
    replace_link "$anchor/skills/$skill_name" "$destination_root/$skill_name" || failures=1
  done

  if [[ "$failures" -ne 0 ]]; then
    echo "install-skills: $label completed with conflicts" >&2
    return 1
  fi
}

install_anchor

status=0
if [[ "$target" == "all" || "$target" == "claude" ]]; then
  install_target "Claude Code" "$claude_dir" || status=1
  prune_stale_links "$claude_dir"
  prune_stale_links "$claude_commands_dir"
fi
if [[ "$target" == "all" || "$target" == "codex" ]]; then
  install_target "Codex" "$codex_dir" || status=1
  prune_stale_links "$codex_dir"
fi

if [[ "$status" -eq 0 ]]; then
  echo "install-skills: complete"
fi

exit "$status"
